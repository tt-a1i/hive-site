---
import type { Lang } from '../i18n'

interface Props {
  lang: Lang
}
const { lang } = Astro.props

const t = lang === 'zh'
  ? {
      label: '— 协调',
      heading: '六个真实的 CLI Coding Agent。一个工作台。',
      sub: '每个 agent 都是你机器上的真实 PTY 进程，互相通过 team 协议对话。',
    }
  : {
      label: '— Orchestrates',
      heading: 'Six real CLI coding agents. One workbench.',
      sub: 'Each agent is a real PTY process on your machine, talking to the others through a small team protocol.',
    }
---

<section class="relative py-20 sm:py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="max-w-2xl">
      <p class="font-mono text-[10.5px] uppercase tracking-[0.28em] text-[var(--color-accent)]">{t.label}</p>
      <h2 class="mt-4 font-display tracking-tight leading-[1.1] text-[var(--color-text)]" style="font-size:clamp(1.6rem,3.2vw,2.4rem);font-weight:380;font-variation-settings:'opsz' 48,'SOFT' 40">
        {t.heading}
      </h2>
      <p class="mt-4 max-w-xl text-[15px] leading-relaxed text-[var(--color-text-muted)]">{t.sub}</p>
    </div>

    <ul class="mt-12 grid grid-cols-2 gap-x-4 gap-y-10 sm:grid-cols-3 sm:gap-x-5 lg:grid-cols-6 lg:gap-x-4">
      {/* Claude Code — Anthropic A wordmark, white on near-black card */}
      <li>
        <a href="https://claude.com/code" target="_blank" rel="noopener" class="group block">
          <div class="flex aspect-square items-center justify-center rounded-xl border border-[var(--color-border)] bg-[#181818] transition group-hover:border-[var(--color-accent)]/45">
            <svg viewBox="0 0 24 24" fill="#ffffff" class="size-[48%]">
              <path d="M17.3041 3.541h-3.6718l6.696 16.918H24Zm-10.6082 0L0 20.459h3.7442l1.3693-3.5527h7.0052l1.3693 3.5528h3.7442L10.5363 3.5409Zm-.3712 10.2232 2.2914-5.9456 2.2914 5.9456Z"/>
            </svg>
          </div>
          <p class="mt-4 text-center text-[14px] font-semibold tracking-tight text-[var(--color-text)]">Claude&nbsp;Code</p>
          <p class="mt-2 flex justify-center">
            <code class="rounded-md border border-[var(--color-border)] bg-[var(--color-surface)]/60 px-2 py-0.5 font-mono text-[11px] text-[var(--color-text-muted)]">claude</code>
          </p>
        </a>
      </li>

      {/* Gemini CLI — Google "G" mark, blue on pale blue card */}
      <li>
        <a href="https://github.com/google-gemini/gemini-cli" target="_blank" rel="noopener" class="group block">
          <div class="flex aspect-square items-center justify-center rounded-xl border border-[var(--color-border)] bg-[#dce6f5] transition group-hover:border-[var(--color-accent)]/45">
            <svg viewBox="0 0 24 24" fill="#1f2937" class="size-[48%]">
              <path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/>
            </svg>
          </div>
          <p class="mt-4 text-center text-[14px] font-semibold tracking-tight text-[var(--color-text)]">Gemini&nbsp;CLI</p>
          <p class="mt-2 flex justify-center">
            <code class="rounded-md border border-[var(--color-border)] bg-[var(--color-surface)]/60 px-2 py-0.5 font-mono text-[11px] text-[var(--color-text-muted)]">gemini</code>
          </p>
        </a>
      </li>

      {/* Codex CLI — OpenAI knot, black on warm white card */}
      <li>
        <a href="https://github.com/openai/codex" target="_blank" rel="noopener" class="group block">
          <div class="flex aspect-square items-center justify-center rounded-xl border border-[var(--color-border)] bg-[#f2efe9] transition group-hover:border-[var(--color-accent)]/45">
            <svg viewBox="0 0 24 24" fill="#0f1115" class="size-[55%]">
              <path d="M22.2819 9.8211a5.9847 5.9847 0 0 0-.5157-4.9108 6.0462 6.0462 0 0 0-6.5098-2.9A6.0651 6.0651 0 0 0 4.9807 4.1818a5.9847 5.9847 0 0 0-3.9977 2.9 6.0462 6.0462 0 0 0 .7427 7.0966 5.98 5.98 0 0 0 .511 4.9107 6.051 6.051 0 0 0 6.5146 2.9001A5.9847 5.9847 0 0 0 13.2599 24a6.0557 6.0557 0 0 0 5.7718-4.2058 5.9894 5.9894 0 0 0 3.9977-2.9001 6.0557 6.0557 0 0 0-.7475-7.0729zm-9.022 12.6081a4.4755 4.4755 0 0 1-2.8764-1.0408l.1419-.0804 4.7783-2.7582a.7948.7948 0 0 0 .3927-.6813v-6.7369l2.02 1.1686a.071.071 0 0 1 .038.052v5.5826a4.504 4.504 0 0 1-4.4945 4.4944zm-9.6607-4.1254a4.4708 4.4708 0 0 1-.5346-3.0137l.142.0852 4.783 2.7582a.7712.7712 0 0 0 .7806 0l5.8428-3.3685v2.3324a.0804.0804 0 0 1-.0332.0615L9.74 19.9502a4.4992 4.4992 0 0 1-6.1408-1.6464zM2.3408 7.8956a4.485 4.485 0 0 1 2.3655-1.9728V11.6a.7664.7664 0 0 0 .3879.6765l5.8144 3.3543-2.0201 1.1685a.0757.0757 0 0 1-.071 0l-4.8303-2.7865A4.504 4.504 0 0 1 2.3408 7.872zm16.5963 3.8558L13.1038 8.364 15.1192 7.2a.0757.0757 0 0 1 .071 0l4.8303 2.7913a4.4944 4.4944 0 0 1-.6765 8.1042v-5.6772a.79.79 0 0 0-.407-.667zm2.0107-3.0231l-.142-.0852-4.7735-2.7818a.7759.7759 0 0 0-.7854 0L9.409 9.2297V6.8974a.0662.0662 0 0 1 .0284-.0615l4.8303-2.7866a4.4992 4.4992 0 0 1 6.6802 4.66zM8.3065 12.863l-2.02-1.1638a.0804.0804 0 0 1-.038-.0567V6.0742a4.4992 4.4992 0 0 1 7.3757-3.4537l-.142.0805L8.704 5.459a.7948.7948 0 0 0-.3927.6813zm1.0976-2.3654l2.602-1.4998 2.6069 1.4998v2.9994l-2.5974 1.4997-2.6067-1.4997Z"/>
            </svg>
          </div>
          <p class="mt-4 text-center text-[14px] font-semibold tracking-tight text-[var(--color-text)]">Codex&nbsp;CLI</p>
          <p class="mt-2 flex justify-center">
            <code class="rounded-md border border-[var(--color-border)] bg-[var(--color-surface)]/60 px-2 py-0.5 font-mono text-[11px] text-[var(--color-text-muted)]">codex</code>
          </p>
        </a>
      </li>

      {/* OpenCode — pixel I mark on near-black card */}
      <li>
        <a href="https://opencode.ai" target="_blank" rel="noopener" class="group block">
          <div class="flex aspect-square items-center justify-center rounded-xl border border-[var(--color-border)] bg-[#131010] transition group-hover:border-[var(--color-accent)]/45">
            <svg viewBox="0 0 512 512" class="size-[60%]">
              <rect width="512" height="512" fill="#131010"/>
              <path d="M320 224V352H192V224H320Z" fill="#5A5858"/>
              <path fill-rule="evenodd" clip-rule="evenodd" d="M384 416H128V96H384V416ZM320 160H192V352H320V160Z" fill="white"/>
            </svg>
          </div>
          <p class="mt-4 text-center text-[14px] font-semibold tracking-tight text-[var(--color-text)]">OpenCode</p>
          <p class="mt-2 flex justify-center">
            <code class="rounded-md border border-[var(--color-border)] bg-[var(--color-surface)]/60 px-2 py-0.5 font-mono text-[11px] text-[var(--color-text-muted)]">opencode</code>
          </p>
        </a>
      </li>

      {/* Qwen Code — geometric Q mark in Qwen purple (redrawn, official SVG not publicly fetchable) */}
      <li>
        <a href="https://github.com/QwenLM/qwen-code" target="_blank" rel="noopener" class="group block">
          <div class="flex aspect-square items-center justify-center rounded-xl border border-[var(--color-border)] bg-[#f4f1ff] transition group-hover:border-[var(--color-accent)]/45">
            <svg viewBox="0 0 24 24" fill="#6f5be8" class="size-[58%]">
              <path d="M12 1.5 L21.2 6.8 L21.2 17.2 L12 22.5 L2.8 17.2 L2.8 6.8 Z"/>
              <path d="M12 5.6 L17.7 8.9 L17.7 15.1 L12 18.4 L6.3 15.1 L6.3 8.9 Z" fill="#f4f1ff"/>
              <path d="M14 14 L20.6 20.6" stroke="#6f5be8" stroke-width="2.2" stroke-linecap="round"/>
              <circle cx="12" cy="12" r="1.5" fill="#6f5be8"/>
            </svg>
          </div>
          <p class="mt-4 text-center text-[14px] font-semibold tracking-tight text-[var(--color-text)]">Qwen&nbsp;Code</p>
          <p class="mt-2 flex justify-center">
            <code class="rounded-md border border-[var(--color-border)] bg-[var(--color-surface)]/60 px-2 py-0.5 font-mono text-[11px] text-[var(--color-text-muted)]">qwen</code>
          </p>
        </a>
      </li>

      {/* OpenClaw — lobster mascot on near-black card */}
      <li>
        <a href="https://openclaw.ai" target="_blank" rel="noopener" class="group block">
          <div class="flex aspect-square items-center justify-center rounded-xl border border-[var(--color-border)] bg-[#0b0d12] transition group-hover:border-[var(--color-accent)]/45">
            <svg viewBox="0 0 120 120" class="size-[62%]">
              <defs>
                <linearGradient id="claw-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#ff4d4d"/>
                  <stop offset="100%" stop-color="#991b1b"/>
                </linearGradient>
              </defs>
              <path d="M60 10 C30 10 15 35 15 55 C15 75 30 95 45 100 L45 110 L55 110 L55 100 C55 100 60 102 65 100 L65 110 L75 110 L75 100 C90 95 105 75 105 55 C105 35 90 10 60 10Z" fill="url(#claw-grad)"/>
              <path d="M20 45 C5 40 0 50 5 60 C10 70 20 65 25 55 C28 48 25 45 20 45Z" fill="url(#claw-grad)"/>
              <path d="M100 45 C115 40 120 50 115 60 C110 70 100 65 95 55 C92 48 95 45 100 45Z" fill="url(#claw-grad)"/>
              <path d="M45 15 Q35 5 30 8" stroke="#ff4d4d" stroke-width="3" stroke-linecap="round" fill="none"/>
              <path d="M75 15 Q85 5 90 8" stroke="#ff4d4d" stroke-width="3" stroke-linecap="round" fill="none"/>
              <circle cx="45" cy="35" r="6" fill="#050810"/>
              <circle cx="75" cy="35" r="6" fill="#050810"/>
              <circle cx="46" cy="34" r="2.5" fill="#00e5cc"/>
              <circle cx="76" cy="34" r="2.5" fill="#00e5cc"/>
            </svg>
          </div>
          <p class="mt-4 text-center text-[14px] font-semibold tracking-tight text-[var(--color-text)]">OpenClaw</p>
          <p class="mt-2 flex justify-center">
            <code class="rounded-md border border-[var(--color-border)] bg-[var(--color-surface)]/60 px-2 py-0.5 font-mono text-[11px] text-[var(--color-text-muted)]">openclaw</code>
          </p>
        </a>
      </li>
    </ul>
  </div>
</section>
