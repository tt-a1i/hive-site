---
import type { Lang } from '../i18n'

interface Props {
  lang: Lang
}
const { lang } = Astro.props

const label = lang === 'zh' ? '— 协调' : '— Orchestrates'
---

<div
  class="reveal mt-9 flex flex-wrap items-center gap-x-6 gap-y-3"
  style="animation-delay:0.40s"
>
  <span class="font-mono text-[10.5px] uppercase tracking-[0.22em] text-[var(--color-text-faint)]">
    {label}
  </span>

  {/* Claude Code — Claude sparkle: asterisk-style 8-ray burst */}
  <a
    href="https://claude.com/code"
    target="_blank"
    rel="noopener"
    class="group inline-flex items-center gap-2 text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" class="text-[var(--color-accent)] opacity-85 transition group-hover:opacity-100">
      <line x1="12" y1="2"   x2="12" y2="22"/>
      <line x1="2"  y1="12"  x2="22" y2="12"/>
      <line x1="4.6" y1="4.6"  x2="19.4" y2="19.4"/>
      <line x1="4.6" y1="19.4" x2="19.4" y2="4.6"/>
    </svg>
    <span class="text-[13px]">Claude&nbsp;Code</span>
  </a>

  {/* Codex — OpenAI knot: nested rotated ellipses */}
  <a
    href="https://github.com/openai/codex"
    target="_blank"
    rel="noopener"
    class="group inline-flex items-center gap-2 text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-accent)] opacity-85 transition group-hover:opacity-100">
      <ellipse cx="12" cy="12" rx="10" ry="4"/>
      <ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(60 12 12)"/>
      <ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(120 12 12)"/>
    </svg>
    <span class="text-[13px]">Codex</span>
  </a>

  {/* Gemini CLI — Google's four-petal twinkle (verbatim path from Google brand) */}
  <a
    href="https://github.com/google-gemini/gemini-cli"
    target="_blank"
    rel="noopener"
    class="group inline-flex items-center gap-2 text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-[var(--color-accent)] opacity-85 transition group-hover:opacity-100">
      <path d="M11.04 19.32Q12 21.51 12 24q0-2.49.93-4.68.96-2.19 2.58-3.81t3.81-2.55Q21.51 12 24 12q-2.49 0-4.68-.93a12.3 12.3 0 0 1-3.81-2.58 12.3 12.3 0 0 1-2.58-3.81Q12 2.49 12 0q0 2.49-.96 4.68-.93 2.19-2.55 3.81a12.3 12.3 0 0 1-3.81 2.58Q2.49 12 0 12q2.49 0 4.68.96 2.19.93 3.81 2.55t2.55 3.81"/>
    </svg>
    <span class="text-[13px]">Gemini&nbsp;CLI</span>
  </a>

  {/* OpenCode — terminal frame with prompt block */}
  <a
    href="https://opencode.ai"
    target="_blank"
    rel="noopener"
    class="group inline-flex items-center gap-2 text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-accent)] opacity-85 transition group-hover:opacity-100">
      <rect x="3" y="5" width="18" height="14" rx="1.5"/>
      <path d="M7 11 L10 13 L7 15" stroke-width="1.6"/>
      <path d="M13 15 L17 15" stroke-width="1.6"/>
    </svg>
    <span class="text-[13px]">OpenCode</span>
  </a>

  {/* Aider — A glyph with raised dot ('i') */}
  <a
    href="https://aider.chat"
    target="_blank"
    rel="noopener"
    class="group inline-flex items-center gap-2 text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-accent)] opacity-85 transition group-hover:opacity-100">
      <path d="M3 20 L9 5 L15 20"/>
      <path d="M5 15 L13 15"/>
      <path d="M19 11 L19 20"/>
      <circle cx="19" cy="7" r="1.3" fill="currentColor" stroke="none"/>
    </svg>
    <span class="text-[13px]">Aider</span>
  </a>

  {/* Hermes — winged staff (caduceus): central rod + two snake twists */}
  <a
    href="https://hermes-agent.nousresearch.com"
    target="_blank"
    rel="noopener"
    class="group inline-flex items-center gap-2 text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-accent)] opacity-85 transition group-hover:opacity-100">
      <path d="M12 3 L12 21"/>
      <path d="M6 6 C 9 4 11 7 12 6 C 13 7 15 4 18 6"/>
      <path d="M6 11 C 9 9 11 12 12 11 C 13 12 15 9 18 11"/>
      <path d="M9 4 L12 2 L15 4"/>
    </svg>
    <span class="text-[13px]">Hermes</span>
  </a>

  {/* OpenClaw — three claw slashes (nodding to the lobster mascot) */}
  <a
    href="https://openclaw.ai"
    target="_blank"
    rel="noopener"
    class="group inline-flex items-center gap-2 text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-accent)] opacity-85 transition group-hover:opacity-100">
      <path d="M6 3 L4.5 13 L8 21"/>
      <path d="M12 3 L12 14 L12 21"/>
      <path d="M18 3 L19.5 13 L16 21"/>
    </svg>
    <span class="text-[13px]">OpenClaw</span>
  </a>
</div>
