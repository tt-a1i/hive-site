---
import HexLogo from './HexLogo.astro'
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-bg)]/80">
  <div class="mx-auto flex max-w-7xl flex-col items-start justify-between gap-8 px-6 py-12 md:flex-row md:items-center">
    <div>
      <a href="/" class="inline-flex items-center gap-2 text-[var(--color-text)]">
        <HexLogo class="text-[var(--color-accent)]" size={20} />
        <span class="font-display text-sm font-semibold tracking-tight">Hive</span>
      </a>
      <p class="mt-3 max-w-md text-sm leading-relaxed text-[var(--color-text-muted)]">
        Browser-native hive-mind for CLI coding agents. Local-first, Apache-2.0, open source.
      </p>
    </div>

    <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
      <a class="text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]" href="https://github.com/tt-a1i/hive">GitHub</a>
      <a class="text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]" href="https://www.npmjs.com/package/@tt-a1i/hive">npm</a>
      <a class="text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]" href="https://github.com/tt-a1i/hive/blob/main/CHANGELOG.md">Changelog</a>
      <a class="text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]" href="https://github.com/tt-a1i/hive/blob/main/SECURITY.md">Security</a>
      <a class="text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]" href="https://github.com/tt-a1i/hive/issues">Issues</a>
    </div>
  </div>

  <div class="border-t border-[var(--color-border)]/60">
    <div class="mx-auto flex max-w-7xl flex-col items-start justify-between gap-3 px-6 py-5 text-xs text-[var(--color-text-faint)] sm:flex-row sm:items-center">
      <div>© 2026 Hive · Licensed under <a href="https://github.com/tt-a1i/hive/blob/main/LICENSE" class="hover:text-[var(--color-text-muted)]">Apache-2.0</a></div>
      <div class="font-mono">
        <span class="text-[var(--color-text-muted)]">$</span>
        <span class="ml-1">npm i -g @tt-a1i/hive</span>
      </div>
    </div>
  </div>
</footer>
