---
import type { Lang } from '../i18n'

interface Props {
  lang: Lang
}
const { lang } = Astro.props

const t = lang === 'zh'
  ? {
      tension: '一个还不够。',
      headline1: '在浏览器里',
      headline2: '看一群 AI 一起干活。',
      subhead:
        '把 Claude、Codex、Gemini 拉进同一个窗口，让它们分工、对话、互相检查——你坐在前面看着就行。全程跑在你自己的电脑上。',
      tryDemo: '看它们干活',
    }
  : {
      tension: 'One AI isn’t enough.',
      headline1: 'Watch a team of AI agents',
      headline2: 'work together in your browser.',
      subhead:
        'Bring Claude, Codex, Gemini and the rest into one window. They split the work, talk to each other, check each other’s output — you just watch. Everything stays on your laptop.',
      tryDemo: 'Watch them work',
    }
---

<section class="relative pt-28 pb-16 sm:pt-36 sm:pb-20">
  {/* faint honeycomb texture — Hive's only brand motif, kept whisper-quiet */}
  <div
    class="honeycomb pointer-events-none absolute inset-0 -z-10 opacity-[0.05]"
    style="mask-image:radial-gradient(ellipse 80% 60% at 50% 30%, black, transparent 75%); -webkit-mask-image:radial-gradient(ellipse 80% 60% at 50% 30%, black, transparent 75%);"
  ></div>

  <div class="mx-auto max-w-6xl px-6">
    {/* tension — a one-line problem statement to set up the headline */}
    <p
      class="reveal text-[15px] font-medium tracking-tight text-[var(--color-text-muted)] sm:text-[16px]"
      style="animation-delay:0.05s"
    >
      {t.tension}
    </p>

    <h1
      class="reveal mt-6 max-w-4xl tracking-[-0.035em] leading-[1.02]"
      style="font-family:'Inter Variable',system-ui,sans-serif;font-size:clamp(2.75rem,6.5vw,5.25rem);font-weight:560;animation-delay:0.15s"
    >
      <span class="text-[var(--color-text)]">{t.headline1}</span>
      <span class="text-[var(--color-text-muted)]"> {t.headline2}</span><span class="cursor align-baseline" aria-hidden="true"></span>
    </h1>

    <p
      class="reveal mt-7 max-w-xl text-[17px] leading-relaxed text-[var(--color-text-muted)] sm:text-[18px]"
      style="animation-delay:0.28s"
    >
      {t.subhead}
    </p>

    <div class="reveal mt-10 flex flex-wrap items-center gap-4" style="animation-delay:0.4s">
      <a
        href="#install"
        class="group inline-flex items-center gap-2 rounded-full bg-[var(--color-text)] px-6 py-3 text-[13.5px] font-semibold text-[var(--color-bg)] transition-all duration-200 ease-out hover:-translate-y-px hover:bg-white hover:shadow-[0_10px_28px_-10px_rgba(90,138,138,0.55)]"
      >
        {t.tryDemo}
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" class="transition group-hover:translate-x-0.5">
          <path d="M5 12h14M13 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
