---
import type { Lang } from '../i18n'
import { STRINGS } from '../i18n'

interface Props {
  lang: Lang
}
const { lang } = Astro.props
const s = STRINGS[lang]
---

<section class="relative overflow-hidden pt-20 pb-12 sm:pt-24 sm:pb-16">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[var(--color-accent)]/40 to-transparent"></div>

  {/* foreground hex anchor — right side, layered, visible at any scale */}
  <svg
    aria-hidden="true"
    class="pointer-events-none absolute right-[-110px] top-[60px] hidden -rotate-[14deg] text-[var(--color-accent)] opacity-[0.55] lg:block xl:right-[-40px]"
    width="520" height="520" viewBox="0 0 520 520" fill="none"
  >
    <path d="M260 30 L460 150 L460 370 L260 490 L60 370 L60 150 Z" stroke="currentColor" stroke-width="1.1"/>
    <path d="M260 105 L395 187.5 L395 332.5 L260 415 L125 332.5 L125 187.5 Z" stroke="currentColor" stroke-width="1" opacity="0.65"/>
    <path d="M260 180 L330 225 L330 295 L260 340 L190 295 L190 225 Z" stroke="currentColor" stroke-width="0.9" opacity="0.4"/>
    <circle cx="260" cy="260" r="6" fill="currentColor" opacity="0.75"/>
  </svg>

  {/* secondary smaller hex bottom-left — cool slate */}
  <svg
    aria-hidden="true"
    class="pointer-events-none absolute left-[-90px] bottom-[20px] hidden rotate-[12deg] text-[var(--color-cool)] opacity-[0.45] md:block"
    width="280" height="280" viewBox="0 0 280 280" fill="none"
  >
    <path d="M140 20 L240 80 L240 200 L140 260 L40 200 L40 80 Z" stroke="currentColor" stroke-width="1"/>
    <path d="M140 65 L208.3 102.5 L208.3 177.5 L140 215 L71.7 177.5 L71.7 102.5 Z" stroke="currentColor" stroke-width="0.9" opacity="0.55"/>
  </svg>

  <div class="mx-auto max-w-6xl px-6">
    {/* editorial kicker */}
    <p class="reveal flex items-center gap-3 font-mono text-[10.5px] uppercase tracking-[0.28em] text-[var(--color-cool)]" style="animation-delay:0.05s">
      <span class="relative flex size-1.5">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--color-accent)] opacity-60"></span>
        <span class="relative inline-flex size-1.5 rounded-full bg-[var(--color-accent)]"></span>
      </span>
      <span class="flex items-center">
        <span class="text-[var(--color-accent)]">{s.hero.kicker.product}</span><span class="mx-3 opacity-50">/</span>{s.hero.kicker.sub}<span class="mx-3 opacity-50">/</span>{s.hero.kicker.version}
      </span>
    </p>

    {/* headline */}
    <h1
      class="reveal mt-10 max-w-[1000px] font-display leading-[0.94] tracking-[-0.025em]"
      style="font-size:clamp(2.8rem,6.6vw,5.75rem);font-weight:280;font-variation-settings:'opsz' 144,'SOFT' 30;animation-delay:0.18s"
    >
      {s.hero.headlinePre && <span class="text-[var(--color-text)]">{s.hero.headlinePre}</span>}<span class="text-[var(--color-text)]" style="font-weight:520;font-variation-settings:'opsz' 144,'SOFT' 20">{s.hero.headlineKey}</span><br/>
      <span class="text-[var(--color-text-muted)]">{s.hero.headlinePost}</span><span class="text-[var(--color-accent)]">.</span>
    </h1>

    {/* subhead */}
    <p
      class="reveal mt-9 max-w-md font-display text-[26px] leading-[1.3] text-[var(--color-text-muted)] sm:text-[30px]"
      style="font-weight:340;font-style:italic;font-variation-settings:'opsz' 18,'SOFT' 90;animation-delay:0.32s"
    >
      {s.hero.subheadLine1}<br/>{s.hero.subheadLine2}
    </p>

    {/* CTA */}
    <div class="reveal mt-12 flex flex-wrap items-center gap-7" style="animation-delay:0.46s">
      <a
        href="https://github.com/tt-a1i/hive#try-the-demo-first"
        class="group inline-flex items-center gap-2 rounded-[5px] bg-[var(--color-accent)] px-5 py-2.5 text-[13px] font-medium text-[#1a1813] shadow-[inset_0_1px_0_0_rgba(255,255,255,0.35),inset_0_-1px_0_0_rgba(0,0,0,0.18),0_1px_0_0_rgba(0,0,0,0.4)] transition-shadow duration-200 hover:bg-[var(--color-accent-hi)] hover:shadow-[inset_0_1px_0_0_rgba(255,255,255,0.45),inset_0_-1px_0_0_rgba(0,0,0,0.22),0_1px_0_0_rgba(0,0,0,0.5),0_0_0_3px_var(--color-accent-soft)]"
      >
        {s.hero.tryDemo}
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" class="transition group-hover:translate-x-0.5">
          <path d="M5 12h14M13 5l7 7-7 7"/>
        </svg>
      </a>
      <a
        href="https://github.com/tt-a1i/hive"
        class="group inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] underline-offset-[6px] transition hover:text-[var(--color-text)] hover:underline"
      >
        {s.hero.viewSource}
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="opacity-50 transition group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:opacity-100">
          <path d="m7 17 10-10M7 7h10v10"/>
        </svg>
      </a>
    </div>
  </div>
</section>
