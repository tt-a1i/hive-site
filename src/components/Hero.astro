---
import type { Lang } from '../i18n'

interface Props {
  lang: Lang
}
const { lang } = Astro.props

const t = lang === 'zh'
  ? {
      status: '浏览器原生 · v0.6.0-alpha.5',
      headline1: '浏览器版蜂巢',
      headline2: '为 CLI Agent 而生。',
      subhead:
        '真实的 CLI agent —— Claude Code、Codex、Gemini、OpenCode、Qwen、Hermes、OpenClaw —— 作为真实 PTY 进程在浏览器里互相协作。本机优先，开源。',
      tryDemo: '试试 demo',
      viewSource: '查看源码',
    }
  : {
      status: 'Browser-native · v0.6.0-alpha.5',
      headline1: 'The hive-mind',
      headline2: 'for CLI coding agents.',
      subhead:
        'Real CLI agents — Claude Code, Codex, Gemini, OpenCode, Qwen, Hermes and more — orchestrated as actual PTY processes in your browser. Local-first, open source.',
      tryDemo: 'Try the demo',
      viewSource: 'View source',
    }
---

<section class="relative pt-28 pb-16 sm:pt-36 sm:pb-20">
  <div class="mx-auto max-w-6xl px-6">
    <p
      class="reveal font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-accent)]"
      style="animation-delay:0.05s"
    >
      {t.status}
    </p>

    <h1
      class="reveal mt-8 max-w-4xl tracking-[-0.035em] leading-[1.02]"
      style="font-family:'Inter Variable',system-ui,sans-serif;font-size:clamp(2.75rem,6.5vw,5.25rem);font-weight:560;animation-delay:0.15s"
    >
      <span class="text-[var(--color-text)]">{t.headline1}</span>
      <span class="text-[var(--color-text-muted)]"> {t.headline2}</span>
    </h1>

    <p
      class="reveal mt-7 max-w-xl text-[17px] leading-relaxed text-[var(--color-text-muted)] sm:text-[18px]"
      style="animation-delay:0.28s"
    >
      {t.subhead}
    </p>

    <div class="reveal mt-10 flex flex-wrap items-center gap-4" style="animation-delay:0.4s">
      <a
        href="https://github.com/tt-a1i/hive#try-the-demo-first"
        class="group inline-flex items-center gap-2 rounded-full bg-[var(--color-text)] px-6 py-3 text-[13.5px] font-semibold text-[var(--color-bg)] transition hover:bg-white"
      >
        {t.tryDemo}
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" class="transition group-hover:translate-x-0.5">
          <path d="M5 12h14M13 5l7 7-7 7"/>
        </svg>
      </a>
      <a
        href="https://github.com/tt-a1i/hive"
        class="group inline-flex items-center gap-2 rounded-full border border-[var(--color-border-hi)] bg-[var(--color-surface)]/40 px-6 py-3 text-[13.5px] font-medium text-[var(--color-text)] backdrop-blur transition hover:border-[var(--color-accent)]/40 hover:bg-[var(--color-surface-2)]"
      >
        {t.viewSource}
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="opacity-60 transition group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:opacity-100">
          <path d="m7 17 10-10M7 7h10v10"/>
        </svg>
      </a>
    </div>
  </div>
</section>
