---
import type { Lang } from '../i18n'

interface Props {
  lang: Lang
}
const { lang } = Astro.props

const t = lang === 'zh'
  ? {
      status: '本地运行 · 开源 · v0.6.0-alpha.5',
      headline1: '看几个 AI',
      headline2: '在你的浏览器里一起干活。',
      subhead:
        '把 Claude、Codex、Gemini 这些 AI 拉到同一个网页，让它们分工、对话、互相检查——你坐在前面看着就行。全程跑在你自己的电脑上。',
      tryDemo: '去看他们干活',
      viewSource: '看看怎么做的',
    }
  : {
      status: 'Runs on your laptop · Open source · v0.6.0-alpha.5',
      headline1: 'Watch a team of AIs',
      headline2: 'work together in your browser.',
      subhead:
        "Bring Claude, Codex, Gemini and friends into one window. They split the work, talk to each other, check each other's output — you just watch. Everything stays on your laptop.",
      tryDemo: 'Watch them work',
      viewSource: "See how it's built",
    }
---

<section class="relative pt-28 pb-16 sm:pt-36 sm:pb-20">
  <div class="mx-auto max-w-6xl px-6">
    <p
      class="reveal font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-accent)]"
      style="animation-delay:0.05s"
    >
      {t.status}
    </p>

    <h1
      class="reveal mt-8 max-w-4xl tracking-[-0.035em] leading-[1.02]"
      style="font-family:'Inter Variable',system-ui,sans-serif;font-size:clamp(2.75rem,6.5vw,5.25rem);font-weight:560;animation-delay:0.15s"
    >
      <span class="text-[var(--color-text)]">{t.headline1}</span>
      <span class="text-[var(--color-text-muted)]"> {t.headline2}</span>
    </h1>

    <p
      class="reveal mt-7 max-w-xl text-[17px] leading-relaxed text-[var(--color-text-muted)] sm:text-[18px]"
      style="animation-delay:0.28s"
    >
      {t.subhead}
    </p>

    <div class="reveal mt-10 flex flex-wrap items-center gap-4" style="animation-delay:0.4s">
      <a
        href="https://github.com/tt-a1i/hive#try-the-demo-first"
        class="group inline-flex items-center gap-2 rounded-full bg-[var(--color-text)] px-6 py-3 text-[13.5px] font-semibold text-[var(--color-bg)] transition hover:bg-white"
      >
        {t.tryDemo}
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" class="transition group-hover:translate-x-0.5">
          <path d="M5 12h14M13 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
