---
import { Picture } from 'astro:assets'
import Layout from '../layouts/Layout.astro'
import Nav from './Nav.astro'
import Hero from './Hero.astro'
import CliGrid from './CliGrid.astro'
import hiveUi from '../assets/screenshots/hive-ui.png'
import type { Lang } from '../i18n'

interface Props {
  lang: Lang
}
const { lang } = Astro.props

const t = lang === 'zh'
  ? {
      installLabel: '一分钟搞定',
      installHint: '复制粘贴一下，AI 们就搬进来了。Node ≥ 22 · Apache-2.0',
      footerNote: 'Hive · 2026',
    }
  : {
      installLabel: 'Up and running in a minute',
      installHint: "Paste it. They'll move in. · Node ≥ 22 · Apache-2.0",
      footerNote: 'Hive · 2026',
    }
---

<Layout lang={lang}>
  <Nav lang={lang} />

  <main>
    <Hero lang={lang} />

    {/* ─── Product screenshot — the page's main visual anchor ───── */}
    <section class="relative overflow-hidden pb-24 sm:pb-32">
      <div class="pointer-events-none absolute left-1/2 top-1/4 -z-10 size-[1100px] -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(90,138,138,0.07),transparent_60%)] blur-[80px]"></div>

      <div class="mx-auto max-w-[1320px] px-6">
        <div class="reveal group relative" style="animation-delay:0.55s">
          <div class="overflow-hidden rounded-2xl border border-white/[0.06] shadow-[0_60px_160px_-40px_rgba(0,0,0,0.75)] transition-transform duration-700 ease-out will-change-transform group-hover:-translate-y-1">
            <Picture
              src={hiveUi}
              formats={['avif', 'webp']}
              widths={[768, 1280, 1920, 2400]}
              sizes="(min-width: 1320px) 1272px, 92vw"
              alt="Hive workbench"
              loading="eager"
              decoding="async"
              class="block w-full"
              pictureAttributes={{ fetchpriority: 'high' }}
            />
          </div>
        </div>
      </div>
    </section>

    {/* ─── Supported CLIs grid ──────────────────────────────────── */}
    <CliGrid lang={lang} />

    {/* ─── Install panel — quiet and competent ──────────────────── */}
    <section class="relative py-20 sm:py-24">
      <div class="mx-auto max-w-3xl px-6">
        <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)]/40 p-8 backdrop-blur-sm sm:p-10">
          <p class="font-mono text-[10.5px] uppercase tracking-[0.22em] text-[var(--color-accent)]">
            {t.installLabel}
          </p>
          <div class="mt-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-2)]/70 p-5 font-mono text-[13px] leading-[1.95]">
            <div class="text-[var(--color-text-faint)]"><span class="select-none text-[var(--color-text-muted)]">$</span> <span class="text-[var(--color-text)]">npm i -g @tt-a1i/hive</span></div>
            <div class="text-[var(--color-text-faint)]"><span class="select-none text-[var(--color-text-muted)]">$</span> <span class="text-[var(--color-text)]">hive --port 4010</span></div>
            <div class="text-[var(--color-text-faint)]"><span class="select-none text-[var(--color-text-muted)]">$</span> <span class="text-[var(--color-text)]">open http://localhost:4010</span></div>
          </div>
          <p class="mt-5 font-mono text-[11px] text-[var(--color-text-faint)]">{t.installHint}</p>
        </div>
      </div>
    </section>

    {/* ─── Footer ──────────────────────────────────────────────── */}
    <footer class="border-t border-[var(--color-border)]/60 py-12">
      <div class="mx-auto flex max-w-6xl flex-col gap-6 px-6 sm:flex-row sm:items-center sm:justify-between">
        <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-text-faint)]">{t.footerNote}</p>
        <div class="flex flex-wrap gap-x-6 gap-y-2 font-mono text-[11px]">
          <a href="https://github.com/tt-a1i/hive" class="text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]">GitHub</a>
          <a href="https://www.npmjs.com/package/@tt-a1i/hive" class="text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]">npm</a>
          <a href="https://github.com/tt-a1i/hive/blob/main/CHANGELOG.md" class="text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]">Changelog</a>
          <a href="https://github.com/tt-a1i/hive/blob/main/LICENSE" class="text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]">Apache-2.0</a>
        </div>
      </div>
    </footer>
  </main>
</Layout>
