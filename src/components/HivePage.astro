---
import { Picture } from 'astro:assets'
import Layout from '../layouts/Layout.astro'
import Nav from './Nav.astro'
import Hero from './Hero.astro'
import CliGrid from './CliGrid.astro'
import hiveUi from '../assets/screenshots/hive-ui.png'
import type { Lang } from '../i18n'

interface Props {
  lang: Lang
}
const { lang } = Astro.props

const t = lang === 'zh'
  ? {
      installLabel: '一分钟搞定',
      footerNote: 'Hive · 2026',
      patterns: {
        label: '这样玩',
        heading: '不是一个 AI 在写——是一群。',
        sub: '同一个工作台里，不同 AI 各司其职。下面是三种最常见的搭法。',
        cards: [
          {
            kicker: '搭法 · 01',
            title: '写 + 审',
            body: 'Claude Code 写代码，Codex 在旁边读、找 bug、留评论。Claude 看完再改。两个 AI 一来一回，一份代码就稳了。',
          },
          {
            kicker: '搭法 · 02',
            title: '测 + 修',
            body: 'Gemini 起好测试，跑一遍。哪条红了立刻甩给 Claude 修。循环到全绿——你只看着进度跳。',
          },
          {
            kicker: '搭法 · 03',
            title: '自定义你的团队',
            body: '不喜欢上面？自己组队。给每个 worker 起个角色名（前端、后端、QA、文档），随便玩。',
          },
        ],
      },
    }
  : {
      installLabel: 'Up and running in a minute',
      footerNote: 'Hive · 2026',
      patterns: {
        label: 'Three ways to play',
        heading: "It's not one AI writing — it's a team.",
        sub: 'Different AIs, different jobs, same workbench. Three patterns we see all the time.',
        cards: [
          {
            kicker: 'Pattern · 01',
            title: 'Write + review',
            body: "Claude Code writes the code. Codex reads it, finds the bugs, leaves notes. Claude reads the notes and rewrites. Two AIs, one tight feedback loop.",
          },
          {
            kicker: 'Pattern · 02',
            title: 'Test + fix',
            body: "Gemini drafts the tests and runs them. Anything red gets handed to Claude to fix. Loop until everything is green — you just watch the indicator.",
          },
          {
            kicker: 'Pattern · 03',
            title: 'Roll your own team',
            body: "Neither of the above? Pick your own crew. Name each worker (frontend, backend, QA, docs) and let them split work the way you want.",
          },
        ],
      },
    }
---

<Layout lang={lang}>
  <Nav lang={lang} />

  <main>
    <Hero lang={lang} />

    {/* ─── Product screenshot — the page's main visual anchor ───── */}
    <section class="relative overflow-hidden pb-24 sm:pb-32">
      <div class="pointer-events-none absolute left-1/2 top-1/4 -z-10 size-[1100px] -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(90,138,138,0.07),transparent_60%)] blur-[80px]"></div>

      <div class="mx-auto max-w-[1320px] px-6">
        <div class="reveal group relative" style="animation-delay:0.55s">
          <div class="overflow-hidden rounded-2xl border border-white/[0.06] shadow-[0_60px_160px_-40px_rgba(0,0,0,0.75)] transition-transform duration-700 ease-out will-change-transform group-hover:-translate-y-1">
            <Picture
              src={hiveUi}
              formats={['avif', 'webp']}
              widths={[768, 1280, 1920, 2400]}
              sizes="(min-width: 1320px) 1272px, 92vw"
              alt="Hive workbench"
              loading="eager"
              decoding="async"
              class="block w-full"
              pictureAttributes={{ fetchpriority: 'high' }}
            />
          </div>
        </div>
      </div>
    </section>

    {/* ─── Use-case patterns — three concrete "what could I do with this?" cards ─ */}
    <section class="relative py-20 sm:py-24">
      <div class="mx-auto max-w-6xl px-6">
        <div class="max-w-2xl">
          <p class="font-mono text-[10.5px] uppercase tracking-[0.22em] text-[var(--color-accent)]">{t.patterns.label}</p>
          <h2
            class="mt-4 tracking-[-0.025em] leading-[1.1] text-[var(--color-text)]"
            style="font-family:'Inter Variable',system-ui,sans-serif;font-size:clamp(1.65rem,3.2vw,2.5rem);font-weight:560"
          >
            {t.patterns.heading}
          </h2>
          <p class="mt-4 max-w-xl text-[15px] leading-relaxed text-[var(--color-text-muted)]">{t.patterns.sub}</p>
        </div>

        <ul class="mt-14 grid grid-cols-1 gap-5 md:grid-cols-3">
          {t.patterns.cards.map((card) => (
            <li class="group rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]/30 p-7 transition-colors duration-300 hover:border-[var(--color-accent)]/40">
              <p class="font-mono text-[10.5px] uppercase tracking-[0.22em] text-[var(--color-text-faint)]">{card.kicker}</p>
              <h3 class="mt-4 text-[19px] font-semibold tracking-tight text-[var(--color-text)]">{card.title}</h3>
              <p class="mt-3 text-[14.5px] leading-relaxed text-[var(--color-text-muted)]">{card.body}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    {/* ─── Supported CLIs grid ──────────────────────────────────── */}
    <CliGrid lang={lang} />

    {/* ─── Install panel — quiet and competent ──────────────────── */}
    <section class="relative py-20 sm:py-24">
      <div class="mx-auto max-w-3xl px-6">
        <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)]/40 p-8 backdrop-blur-sm sm:p-10">
          <p class="font-mono text-[10.5px] uppercase tracking-[0.22em] text-[var(--color-accent)]">
            {t.installLabel}
          </p>
          <div class="mt-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-2)]/70 p-5 font-mono text-[13px] leading-[1.95]">
            <div class="text-[var(--color-text-faint)]"><span class="select-none text-[var(--color-text-muted)]">$</span> <span class="text-[var(--color-text)]">npm i -g @tt-a1i/hive</span></div>
            <div class="text-[var(--color-text-faint)]"><span class="select-none text-[var(--color-text-muted)]">$</span> <span class="text-[var(--color-text)]">hive --port 4010</span></div>
            <div class="text-[var(--color-text-faint)]"><span class="select-none text-[var(--color-text-muted)]">$</span> <span class="text-[var(--color-text)]">open http://localhost:4010</span></div>
          </div>
        </div>
      </div>
    </section>

    {/* ─── Footer ──────────────────────────────────────────────── */}
    <footer class="border-t border-[var(--color-border)]/60 py-12">
      <div class="mx-auto flex max-w-6xl flex-col gap-6 px-6 sm:flex-row sm:items-center sm:justify-between">
        <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-text-faint)]">{t.footerNote}</p>
        <div class="flex flex-wrap gap-x-6 gap-y-2 font-mono text-[11px]">
          <a href="https://github.com/tt-a1i/hive" class="text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]">GitHub</a>
          <a href="https://www.npmjs.com/package/@tt-a1i/hive" class="text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]">npm</a>
          <a href="https://github.com/tt-a1i/hive/blob/main/CHANGELOG.md" class="text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]">Changelog</a>
          <a href="https://github.com/tt-a1i/hive/blob/main/LICENSE" class="text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]">Apache-2.0</a>
        </div>
      </div>
    </footer>
  </main>
</Layout>
