---
import { Picture } from 'astro:assets'
import Layout from '../layouts/Layout.astro'
import Nav from './Nav.astro'
import Hero from './Hero.astro'
import hiveUi from '../assets/screenshots/hive-ui.png'
import type { Lang } from '../i18n'
import { STRINGS } from '../i18n'

interface Props {
  lang: Lang
}
const { lang } = Astro.props
const s = STRINGS[lang]
---

<Layout lang={lang}>
  <Nav lang={lang} />

  <main>
    <Hero lang={lang} />

    {/* ─── Section transition — editorial divider ─────────────── */}
    <div class="mx-auto max-w-6xl px-6 pb-12">
      <div class="flex items-center gap-5">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent to-[var(--color-border-hi)]"></div>
        <div class="flex items-center gap-3">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" class="text-[var(--color-accent)]">
            <path d="M12 2.5 L20.4 7.25 L20.4 16.75 L12 21.5 L3.6 16.75 L3.6 7.25 Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" fill="currentColor" fill-opacity="0.1"/>
          </svg>
          <p class="font-mono text-[10.5px] uppercase tracking-[0.3em] text-[var(--color-text-faint)]">
            <span class="text-[var(--color-text-muted)]">{s.workbench.figLabel}</span><span class="mx-3 opacity-50">/</span>{s.workbench.figTitle}
          </p>
        </div>
        <div class="h-px flex-1 bg-gradient-to-r from-[var(--color-border-hi)] to-transparent"></div>
      </div>
    </div>

    {/* ─── Product screenshot — single atmospheric gesture ─────── */}
    <section class="relative overflow-hidden pb-32">
      <div class="pointer-events-none absolute left-1/2 top-1/3 -z-10 size-[900px] -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(211,152,96,0.06),transparent_60%)] blur-[60px]"></div>

      <div class="mx-auto max-w-6xl px-6">
        <div class="reveal group relative" style="animation-delay:0.65s">
          <div class="absolute -top-px inset-x-12 h-px bg-gradient-to-r from-transparent via-[var(--color-accent)]/60 to-transparent"></div>

          <div class="overflow-hidden rounded-2xl border border-white/[0.06] shadow-[0_60px_140px_-40px_rgba(0,0,0,0.7)] transition-transform duration-700 ease-out will-change-transform group-hover:-translate-y-1">
            <Picture
              src={hiveUi}
              formats={['avif', 'webp']}
              widths={[768, 1280, 1920, 2400]}
              sizes="(min-width: 1280px) 1152px, 90vw"
              alt="Hive workbench"
              loading="eager"
              decoding="async"
              class="block w-full"
              pictureAttributes={{ fetchpriority: 'high' }}
            />
          </div>
        </div>

        <div class="mt-8 flex items-center justify-between font-mono text-[10.5px] uppercase tracking-[0.22em] text-[var(--color-text-faint)]">
          <span>{s.workbench.figLabel}</span>
          <span class="hidden sm:inline">{s.workbench.figCaption} <span class="text-[var(--color-text-muted)]">{s.workbench.figCaptionAt}</span></span>
          <span>2026</span>
        </div>
      </div>
    </section>

    {/* ─── Closing manifest — editorial pull-quote ─────────────── */}
    <section class="relative overflow-hidden pb-32">
      <svg
        aria-hidden="true"
        class="pointer-events-none absolute -right-[14%] top-[10%] -z-10 h-[420px] w-[420px] rotate-[18deg] text-[var(--color-accent)] opacity-[0.06]"
        viewBox="0 0 24 24" fill="none"
      >
        <path d="M12 2 L21 7 L21 17 L12 22 L3 17 L3 7 Z" stroke="currentColor" stroke-width="0.5"/>
      </svg>

      <div class="mx-auto max-w-4xl px-6 pt-20">
        <p class="font-mono text-[10.5px] uppercase tracking-[0.28em] text-[var(--color-cool)]">
          {s.note.kicker}
        </p>
        <blockquote
          class="mt-7 font-display leading-[1.15] tracking-[-0.015em] text-[var(--color-text)]"
          style="font-size:clamp(1.75rem,3.4vw,2.75rem);font-weight:340;font-style:italic;font-variation-settings:'opsz' 48,'SOFT' 60"
        >
          {s.note.line1}<br/>
          <span class="text-[var(--color-text-muted)]">{s.note.line2}</span><br/>
          <span class="text-[var(--color-text-faint)]">{s.note.line3}</span>
        </blockquote>

        {/* closing CTA card */}
        <div class="group mt-14 rounded-2xl border border-[var(--color-border-hi)] bg-[var(--color-surface)]/40 p-8 backdrop-blur-sm transition-colors duration-500 hover:border-[var(--color-accent)]/40 sm:p-10">
          <div class="flex flex-col gap-7 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <p class="font-mono text-[10.5px] uppercase tracking-[0.28em] text-[var(--color-accent)]">{s.cta.kicker}</p>
              <p class="mt-3 font-display text-[22px] leading-snug text-[var(--color-text)]" style="font-weight:380;font-variation-settings:'opsz' 32,'SOFT' 40">
                {s.cta.title}
              </p>
            </div>
            <div class="flex flex-shrink-0 flex-wrap items-center gap-4">
              <a
                href="https://github.com/tt-a1i/hive#try-the-demo-first"
                class="group inline-flex items-center gap-2 rounded-[5px] bg-[var(--color-accent)] px-5 py-2.5 text-[13px] font-medium text-[#1a1813] shadow-[inset_0_1px_0_0_rgba(255,255,255,0.35),inset_0_-1px_0_0_rgba(0,0,0,0.18),0_1px_0_0_rgba(0,0,0,0.4)] transition-shadow duration-200 hover:bg-[var(--color-accent-hi)] hover:shadow-[inset_0_1px_0_0_rgba(255,255,255,0.45),inset_0_-1px_0_0_rgba(0,0,0,0.22),0_1px_0_0_rgba(0,0,0,0.5),0_0_0_3px_var(--color-accent-soft)]"
              >
                {s.cta.tryDemo}
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" class="transition group-hover:translate-x-0.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
              <a
                href="https://github.com/tt-a1i/hive"
                class="group inline-flex items-center gap-1.5 text-[13px] text-[var(--color-text-muted)] underline-offset-[6px] transition hover:text-[var(--color-text)] hover:underline"
              >
                {s.cta.viewSource}
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="opacity-50 transition group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:opacity-100"><path d="m7 17 10-10M7 7h10v10"/></svg>
              </a>
            </div>
          </div>

          <div class="mt-8 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-2)]/60 p-5 font-mono text-[12.5px] leading-[1.85]">
            <div class="text-[var(--color-text-faint)]"><span class="select-none text-[var(--color-text-muted)]">$</span> <span class="text-[var(--color-text)]">npm i -g @tt-a1i/hive</span></div>
            <div class="text-[var(--color-text-faint)]"><span class="select-none text-[var(--color-text-muted)]">$</span> <span class="text-[var(--color-text)]">hive --port 4010</span></div>
          </div>
        </div>

        {/* colophon */}
        <div class="mt-16 grid grid-cols-2 gap-x-10 gap-y-5 border-t border-[var(--color-border)]/60 pt-10 font-mono text-[11px] sm:grid-cols-4">
          <div>
            <p class="text-[10px] uppercase tracking-[0.22em] text-[var(--color-text-faint)]">{s.colophon.repository}</p>
            <a href="https://github.com/tt-a1i/hive" class="group mt-2 inline-flex items-center gap-1.5 text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]">
              tt-a1i/hive
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" class="opacity-50 transition group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:opacity-100">
                <path d="m7 17 10-10M7 7h10v10"/>
              </svg>
            </a>
          </div>
          <div>
            <p class="text-[10px] uppercase tracking-[0.22em] text-[var(--color-text-faint)]">{s.colophon.package}</p>
            <a href="https://www.npmjs.com/package/@tt-a1i/hive" class="group mt-2 inline-flex items-center gap-1.5 text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]">
              @tt-a1i/hive
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" class="opacity-50 transition group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:opacity-100">
                <path d="m7 17 10-10M7 7h10v10"/>
              </svg>
            </a>
          </div>
          <div>
            <p class="text-[10px] uppercase tracking-[0.22em] text-[var(--color-text-faint)]">{s.colophon.license}</p>
            <a href="https://github.com/tt-a1i/hive/blob/main/LICENSE" class="mt-2 inline-block text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]">Apache-2.0</a>
          </div>
          <div>
            <p class="text-[10px] uppercase tracking-[0.22em] text-[var(--color-text-faint)]">{s.colophon.requires}</p>
            <p class="mt-2 text-[var(--color-text-muted)]">{s.colophon.requiresValue}</p>
          </div>
        </div>

        <div class="mt-7 flex flex-wrap gap-x-6 gap-y-2 font-mono text-[11px]">
          <a href="https://github.com/tt-a1i/hive#readme" class="text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]">{s.colophon.readme}</a>
          <a href="https://github.com/tt-a1i/hive/blob/main/CHANGELOG.md" class="text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]">{s.colophon.changelog}</a>
          <a href="https://github.com/tt-a1i/hive/blob/main/SECURITY.md" class="text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]">{s.colophon.security}</a>
          <a href="https://github.com/tt-a1i/hive/blob/main/CONTRIBUTING.md" class="text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]">{s.colophon.contributing}</a>
          <a href="https://github.com/tt-a1i/hive/issues" class="text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]">{s.colophon.issues}</a>
        </div>

        <div class="mt-12 flex items-center justify-between border-t border-[var(--color-border)]/60 pt-6 font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--color-text-faint)]">
          <span class="inline-flex items-center gap-2">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none">
              <path d="M12 2.5 L20.4 7.25 L20.4 16.75 L12 21.5 L3.6 16.75 L3.6 7.25 Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" fill="currentColor" fill-opacity="0.1"/>
            </svg>
            {s.colophon.signoff}
          </span>
          <span class="inline-flex items-center gap-1.5">
            <span class="size-1 rounded-full bg-[var(--color-accent)] opacity-70"></span>
            v0.6.0-alpha.5
          </span>
        </div>
      </div>
    </section>
  </main>
</Layout>
