---
import HexLogo from './HexLogo.astro'
import type { Lang } from '../i18n'
import { STRINGS } from '../i18n'

interface Props {
  lang: Lang
}
const { lang } = Astro.props
const s = STRINGS[lang]
const homeHref = lang === 'zh' ? '/' : '/en/'
---

<nav class="absolute inset-x-0 top-0 z-40">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 pt-6">
    <a href={homeHref} class="group flex items-center gap-2.5 text-[var(--color-text)]">
      <HexLogo class="text-[var(--color-accent)] transition duration-500 group-hover:rotate-[14deg]" glow size={24} />
      <span class="font-display text-[19px] font-medium tracking-tight" style="font-variation-settings:'opsz' 60,'SOFT' 30">Hive</span>
    </a>

    <div class="flex items-center gap-2">
      {/* Language switcher */}
      <a
        href={s.nav.switcherHref}
        class="group inline-flex items-center gap-1.5 rounded-md px-2.5 py-1.5 font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]"
      >
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="opacity-60">
          <circle cx="12" cy="12" r="9"/>
          <path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/>
        </svg>
        {s.nav.switcherLabel}
      </a>

      {/* npm — icon-only ghost */}
      <a
        href="https://www.npmjs.com/package/@tt-a1i/hive"
        aria-label="npm package"
        class="group inline-flex size-9 items-center justify-center rounded-md border border-[var(--color-border-hi)] bg-[var(--color-surface)]/40 text-[var(--color-text-muted)] backdrop-blur transition hover:border-[var(--color-accent)]/40 hover:bg-[var(--color-surface-2)] hover:text-[var(--color-text)]"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
          <path d="M0 7.334v8h6.666v1.332H12V15.334h12v-8zm6.666 6.664H5.334v-4H3.999v4H1.334V8.667h5.332zm4 0v1.336H8.001V8.667h5.334v5.331zm11.998 0h-1.33v-4h-1.336v4h-1.334v-4h-1.332v4h-2.668V8.667h8z"/>
        </svg>
      </a>

      {/* GitHub — Star button */}
      <a
        href="https://github.com/tt-a1i/hive"
        class="group inline-flex items-center gap-2 rounded-md border border-[var(--color-border-hi)] bg-[var(--color-surface)]/40 px-3.5 py-1.5 text-[12.5px] font-medium text-[var(--color-text)] backdrop-blur transition hover:border-[var(--color-accent)]/40 hover:bg-[var(--color-surface-2)]"
      >
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
          <path d="M8 0a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38v-1.34c-2.22.48-2.69-1.07-2.69-1.07-.36-.92-.89-1.17-.89-1.17-.73-.5.06-.49.06-.49.8.06 1.23.83 1.23.83.72 1.23 1.88.87 2.34.66.07-.52.28-.87.5-1.07-1.77-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0 0 8 0Z"/>
        </svg>
        <span>{s.nav.star}</span>
        <span class="hidden h-3.5 w-px bg-[var(--color-border-hi)] sm:inline-block"></span>
        <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" class="hidden text-[var(--color-accent)] sm:inline">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/>
        </svg>
      </a>
    </div>
  </div>
</nav>
