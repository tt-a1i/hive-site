---
import type { Lang } from '../i18n'
import { STRINGS } from '../i18n'

interface Props {
  lang: Lang
}
const { lang } = Astro.props
const s = STRINGS[lang]
const homeHref = lang === 'zh' ? '/' : '/en/'
---

<nav class="absolute inset-x-0 top-0 z-40">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 pt-6">
    <a href={homeHref} class="group inline-flex items-center gap-2.5 text-[var(--color-text)]">
      <img src="/logo-256.png" alt="" width="56" height="56" class="size-14 transition-transform duration-500 ease-out group-hover:-translate-y-px" />
      <span class="text-[28px] font-semibold tracking-tight">Hive</span>
    </a>

    <div class="flex items-center gap-2">
      {/* Language switcher */}
      <a
        href={s.nav.switcherHref}
        hreflang={lang === 'zh' ? 'en' : 'zh-CN'}
        lang={lang === 'zh' ? 'en' : 'zh-CN'}
        aria-label={lang === 'zh' ? 'Switch language to English' : '切换到中文'}
        class="group inline-flex items-center gap-1.5 rounded-md px-2.5 py-1.5 font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-text-muted)] transition-colors duration-150 ease-out hover:text-[var(--color-text)]"
      >
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="opacity-60" aria-hidden="true" focusable="false">
          <circle cx="12" cy="12" r="9"/>
          <path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/>
        </svg>
        {s.nav.switcherLabel}
      </a>

      {/* GitHub — Star button */}
      <a
        href="https://github.com/tt-a1i/hive"
        class="group inline-flex items-center gap-2 rounded-md border border-[var(--color-border-hi)] bg-[var(--color-surface)]/40 px-3.5 py-1.5 text-[12.5px] font-medium text-[var(--color-text)] backdrop-blur transition-colors duration-150 ease-out hover:border-[var(--color-accent)]/40 hover:bg-[var(--color-surface-2)] active:bg-[var(--color-surface-2)]/70 active:duration-75"
      >
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" focusable="false">
          <path d="M8 0a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38v-1.34c-2.22.48-2.69-1.07-2.69-1.07-.36-.92-.89-1.17-.89-1.17-.73-.5.06-.49.06-.49.8.06 1.23.83 1.23.83.72 1.23 1.88.87 2.34.66.07-.52.28-.87.5-1.07-1.77-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0 0 8 0Z"/>
        </svg>
        <span>{s.nav.star}</span>
        <span class="hidden h-3.5 w-px bg-[var(--color-border-hi)] sm:inline-block" aria-hidden="true"></span>
        <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" class="hidden text-[var(--color-accent)] sm:inline" aria-hidden="true" focusable="false">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/>
        </svg>
      </a>
    </div>
  </div>
</nav>
