---
import '../styles/global.css'
import type { Lang } from '../i18n'
import { STRINGS } from '../i18n'

interface Props {
  lang?: Lang
}

const { lang = 'en' } = Astro.props
const s = STRINGS[lang]
const baseUrl = 'https://hivehq.dev'
const path = lang === 'zh' ? '/' : '/en/'
const canonicalUrl = `${baseUrl}${path}`

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Hive',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Linux, Windows',
  description: s.meta.description,
  url: canonicalUrl,
  license: 'https://mariadb.com/bsl11/',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author: { '@type': 'Person', name: '@tt-a1i', url: 'https://github.com/tt-a1i' },
  sameAs: [
    'https://github.com/tt-a1i/hive',
    'https://www.npmjs.com/package/@tt-a1i/hive',
  ],
}
---

<!doctype html>
<html lang={s.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logo-32.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/logo-64.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/logo-180.png" />
    <meta name="generator" content={Astro.generator} />

    <title>{s.meta.title}</title>
    <meta name="description" content={s.meta.description} />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="zh-CN" href={`${baseUrl}/`} />
    <link rel="alternate" hreflang="en" href={`${baseUrl}/en/`} />
    <link rel="alternate" hreflang="x-default" href={`${baseUrl}/`} />

    <meta property="og:title" content={s.meta.title} />
    <meta property="og:description" content={s.meta.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${baseUrl}/og.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'zh' ? 'en_US' : 'zh_CN'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={s.meta.title} />
    <meta name="twitter:description" content={s.meta.description} />
    <meta name="twitter:image" content={`${baseUrl}/og.png`} />

    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#fafaf7" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
  </body>
</html>
