---
import '../styles/global.css'
import HexLogo from '../components/HexLogo.astro'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1200,initial-scale=1" />
    <title>OG Card</title>
    <style>
      html, body { margin: 0; padding: 0; overflow: hidden; }
      body { width: 1200px; height: 630px; }
    </style>
  </head>
  <body class="bg-[var(--color-bg)]">
    <div class="relative h-[630px] w-[1200px] overflow-hidden">
      {/* honey radial halo top-left */}
      <div class="pointer-events-none absolute -left-[15%] -top-[40%] size-[900px] rounded-full bg-[radial-gradient(circle,rgba(211,152,96,0.10),transparent_65%)] blur-[80px]"></div>

      {/* top honey hairline */}
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[var(--color-accent)]/55 to-transparent"></div>

      {/* right floating hexagon — Hive signature */}
      <svg
        aria-hidden="true"
        class="pointer-events-none absolute -right-[80px] -top-[40px] -rotate-[14deg] text-[var(--color-accent)] opacity-[0.62]"
        width="640" height="640" viewBox="0 0 520 520" fill="none"
      >
        <path d="M260 30 L460 150 L460 370 L260 490 L60 370 L60 150 Z" stroke="currentColor" stroke-width="1.2"/>
        <path d="M260 105 L395 187.5 L395 332.5 L260 415 L125 332.5 L125 187.5 Z" stroke="currentColor" stroke-width="1.1" opacity="0.65"/>
        <path d="M260 180 L330 225 L330 295 L260 340 L190 295 L190 225 Z" stroke="currentColor" stroke-width="1" opacity="0.45"/>
        <circle cx="260" cy="260" r="7" fill="currentColor" opacity="0.8"/>
      </svg>

      {/* secondary smaller hex bottom-right */}
      <svg
        aria-hidden="true"
        class="pointer-events-none absolute -right-[40px] -bottom-[60px] rotate-[8deg] text-[var(--color-cool)] opacity-[0.32]"
        width="260" height="260" viewBox="0 0 280 280" fill="none"
      >
        <path d="M140 20 L240 80 L240 200 L140 260 L40 200 L40 80 Z" stroke="currentColor" stroke-width="1.2"/>
      </svg>

      {/* content */}
      <div class="relative flex h-full flex-col justify-between p-20">
        {/* TOP — logo + wordmark + version */}
        <div class="flex items-center gap-3">
          <HexLogo class="text-[var(--color-accent)]" glow size={36} />
          <span class="font-display text-[28px] font-medium tracking-tight text-[var(--color-text)]" style="font-variation-settings:'opsz' 60,'SOFT' 30">Hive</span>
          <span class="ml-3 rounded-md border border-[var(--color-border-hi)] bg-[var(--color-surface)]/60 px-2 py-0.5 font-mono text-[12px] uppercase tracking-[0.18em] text-[var(--color-text-muted)]">
            v0.6.0-alpha.5
          </span>
        </div>

        {/* MIDDLE — headline */}
        <div class="max-w-[820px]">
          <h1
            class="font-display leading-[0.96] tracking-[-0.025em]"
            style="font-size:96px;font-weight:280;font-variation-settings:'opsz' 144,'SOFT' 30"
          >
            <span class="text-[var(--color-text)]">The </span><span class="text-[var(--color-text)]" style="font-weight:520;font-variation-settings:'opsz' 144,'SOFT' 20">hive-mind</span><br/>
            <span class="text-[var(--color-text-muted)]">for CLI coding agents</span><span class="text-[var(--color-accent)]">.</span>
          </h1>

          <p
            class="mt-7 font-display text-[28px] leading-snug text-[var(--color-text-muted)]"
            style="font-weight:340;font-style:italic;font-variation-settings:'opsz' 24,'SOFT' 90"
          >
            Real CLIs. Real PTYs. In your browser.
          </p>
        </div>

        {/* BOTTOM — URL + meta */}
        <div class="flex items-center justify-between font-mono text-[14px] uppercase tracking-[0.22em] text-[var(--color-text-faint)]">
          <span class="inline-flex items-center gap-2">
            <span class="size-1.5 rounded-full bg-[var(--color-accent)]"></span>
            <span class="text-[var(--color-text-muted)]">hive-site.pages.dev</span>
          </span>
          <span>Apache-2.0 · Node ≥ 22 · open source</span>
        </div>
      </div>
    </div>
  </body>
</html>
